// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Analytics {
  id String
  name String
  status String
  created_at DateTime
  updated_at DateTime
}

model Auths {
  id String
  email String
  password_hash String
  status String
  created_at DateTime
  updated_at DateTime
}

model Contents {
  id String
  name String
  status String
  created_at DateTime
  updated_at DateTime
}

model Notifications {
  id String
  name String
  status String
  created_at DateTime
  updated_at DateTime
}

model Profiles {
  id String
  name String
  status String
  created_at DateTime
  updated_at DateTime
}

model Searchs {
  id String
  name String
  status String
  created_at DateTime
  updated_at DateTime
}

model Experiences {
  id String
  name String
  status String
  created_at DateTime
  updated_at DateTime
}

model Operations {
  id String
  name String
  status String
  created_at DateTime
  updated_at DateTime
}

model Cores {
  id String
  name String
  status String
  created_at DateTime
  updated_at DateTime
}
